<style>
  .spacer {
    height: 8px;
  }

  /* HERO SECTION */

  #hero {
    display: grid;
    place-items: center;
    padding: 0 3rem;
    margin: auto;
    grid-template-columns: 1fr 1fr;
  }

  .hero--h1 {
    margin-top: 4rem;
    font-size: 4rem;
    font-family: var(--serif);
    font-weight: 500;
  }

  .hero--h2 {
    margin-bottom: 0.5rem;
    font-size: 2rem;
    font-weight: 200;
  }

  .hero--h3 {
    font-size: 1.5rem;
    text-align: left;
    width: 100%;
    font-weight: 600;
    margin-bottom: 0.75rem;
    font-family: var(--serif);
  }

  .hero--description {
    margin-bottom: 4rem;
  }

  .hero--role-list {
    display: flex;
    flex-direction: row;
    gap: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .hero--role {
    padding: 0.5rem 1rem;
    border-radius: 50rem;
    background-color: var(--dark-text);
    color: var(--light-text);
    font-weight: 600;
    font-size: 0.8rem;
  }

  /* Right side hero section */

  .hero--picutre-section {
    outline: 1px solid var(--dark-text);
    background-color: var(--background-color-light);
    margin: 2rem 1rem;
    padding: 1rem;
  }

  .hero--wireframe-wrapper {
    display: flex;
    flex-direction: row;
    background-color:;
    padding: 1rem 0.5rem;
  }

  .hero--wireframe {
    width: 30%;
    margin: auto;
    outline: 1px solid var(--dark-text);
    box-shadow: 2px 2px 1px 1px var(--dark-text);
    border-radius: 1rem;
  }

  .hero--wireframe-text-wrapper {
    margin-top: 0.5rem;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
  }

  .hero--wireframe-description {
    margin-bottom: 2rem;
  }

  .hero--wireframe-button {
    text-align: center;
    margin: auto;
    margin-bottom: 1rem;

    padding: 0.75rem 1.5rem;
    background-color: var(--primary-color);
    color: var(--light-text);
    font-weight: 600;
    font-size: 1rem;
    box-shadow: 2px 2px 1px 1px var(--dark-text);

    border-radius: 1rem;
    transition: 0.1s ease;
  }

  .hero--wireframe-button:hover {
    opacity: 70%;
    cursor: pointer;
  }

  .hero--wireframe-button:active {
    transform: translateY(2px) translateX(2px);
    box-shadow: none;
  }

  .hero--wireframe-button-hollow {
    text-align: center;
    margin: auto;
    margin-bottom: 1rem;
    padding: 0.75rem 1.5rem;
    background-color: var(--background-color-light);
    color: var(--dark-text);
    font-weight: 600;
    font-size: 1rem;
    box-shadow: 2px 2px 1px 1px var(--dark-text);
    outline: 1px solid var(--dark-text);
    border-radius: 1rem;
    transition: 0.1s ease;
  }

  .hero--wireframe-button-hollow:hover {
    opacity: 70%;
    cursor: pointer;
  }

  .hero--wireframe-button-hollow:active {
    transform: translateY(2px) translateX(2px);
    box-shadow: none;
  }

  /* Timeline */

  #timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline--h1 {
    margin-top: 2rem;

    font-size: 3rem;
    font-family: var(--serif);
    font-weight: 500;
  }

  .timeline--hr {
    margin-bottom: 2rem;
  }

  .timeline--wrapper {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    padding: 0 3rem;
  }

  .timeline--card {
    background-color: var(--background-color-light);
    padding: 1rem;
    outline: 1px solid var(--dark-text);
    border-radius: 1rem;
  }

  .timeline--card-title {
    font-size: 1.25rem;
    font-weight: 600;
    text-align: center;
    margin-bottom: 0.5rem;
    /* font-family: var(--serif); */
  }

  /* BOttom part */

  .timeline--info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin: auto;
    place-items: center;
    margin-top: 2rem;

    width: 100%;
  }

  .timeline--h2 {
    margin-bottom: 0.5rem;
    font-size: 2rem;
    font-weight: 200;
  }

  .timeline--button-wrapper {
    display: flex;
    flex-direction: column;
  }
</style>

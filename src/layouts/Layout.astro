---
import "../styles/reset.css";
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/bridget-portfolio/favicon.svg"
    />
    <link rel="icon" href="/bridget-portfolio/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Bridget Baron {title}</title>
  </head>

  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>

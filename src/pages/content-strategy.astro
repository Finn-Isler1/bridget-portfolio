---
import Layout from "../layouts/Layout.astro";
import WorkNav from "../components/WorkNav.astro";

const title = "Work";
---

<Layout>
  <div class="spacer"></div>
  <WorkNav />
  <section id="hero">
    <div class="hero--text">
      <h1 class="hero--h1">Digital Media Brand</h1>
      <h2 class="hero--h2">Marketing & Content Strategy Manager</h2>
      <p class="hero--description">
        This case study details how data-driven content strategy and operational
        systems can drive rapid audience growth on short-form platforms. The
        overview highlights my process for analyzing performance, structuring
        creative workflows, and scaling a digital media brand.
      </p>
      <h3 class="hero--h3">My Roles:</h3>
      <ul class="hero--role-list">
        <li class="hero--role">Content Strategy</li>
        <li class="hero--role">Operations</li>
        <li class="hero--role">Brand Partnerships</li>
      </ul>
    </div>
    <div class="hero--picutre-section">
      <div class="hero--wireframe-text-wrapper">
        <div class="hero--wireframe-wrapper">
          <img
            class="hero--wireframe"
            src="/bridget-portfolio/assets/IMG_5514.jpg"
          />
          <img
            class="hero--wireframe"
            src="/bridget-portfolio/assets/IMG_5507.jpg"
          />
          <img
            class="hero--wireframe"
            src="/bridget-portfolio/assets/IMG_5502.jpg"
          />
        </div>
        <p class="hero--wireframe-description">
          I managed content strategy and operational workflows for a
          digital media brand on Instagram and TikTok targeting men ages 18–24.
          The brand focuses on short-form storytelling, lifestyle content, and
          surreal humor scenarios designed for high shareability and retention.
          Within three months, the account grew from ~10K to over 100K
          followers, generating 242M+ cumulative views, 47M+ accounts reached,
          and 20M+ likes across platforms.
        </p>
        <div class="hero--stats-wrapper">
          <div class="hero--stat">
            <span class="hero--stat-number">242M+</span>
            <span class="hero--stat-label">Cumulative Views</span>
          </div>
          <div class="hero--stat">
            <span class="hero--stat-number">47M+</span>
            <span class="hero--stat-label">Accounts Reached</span>
          </div>
          <div class="hero--stat">
            <span class="hero--stat-number">10x</span>
            <span class="hero--stat-label">Follower Growth</span>
          </div>
        </div>
      </div>
    </div>
  </section>
  <hr />
  <section id="timeline">
    <h1 class="timeline--h1">Process</h1>
    <hr class="timeline--hr" />
    <div class="timeline--wrapper">
      <div class="timeline--card">
        <p class="timeline--card-title">Performance Analysis</p>
        <p class="timeline--card-description">
          Reviewed Instagram and TikTok analytics to identify high-performing
          formats, watch time patterns, and audience behavior.
        </p>
      </div>
      <div class="timeline--card">
        <p class="timeline--card-title">Concept Development</p>
        <p class="timeline--card-description">
          Led brainstorming sessions with the creator to develop new content
          ideas and refine existing concepts.
        </p>
      </div>
      <div class="timeline--card">
        <p class="timeline--card-title">Script & Story Structure</p>
        <p class="timeline--card-description">
          Wrote short screenplays for each concept outlining the hook, key
          visual moments, narrative beats, and payoff.
        </p>
      </div>
      <div class="timeline--card">
        <p class="timeline--card-title">Production & Execution</p>
        <p class="timeline--card-description">
          Executed concepts through filming and fast-paced editing designed for
          strong visual engagement.
        </p>
      </div>
      <div class="timeline--card">
        <p class="timeline--card-title">Publishing Optimization</p>
        <p class="timeline--card-description">
          Scheduled posts using platform analytics to publish during peak
          engagement windows.
        </p>
      </div>
      <div class="timeline--card">
        <p class="timeline--card-title">Operational Systems</p>
        <p class="timeline--card-description">
          Built automated workflows using Zapier, Notion, and Google Calendar to
          manage brand partnerships.
        </p>
      </div>
    </div>
    <div class="timeline--info">
      <div class="timeline--info-text">
        <h2 class="timeline--h2">Impact & Outcome</h2>
        <p class="timeline-description">
          The account grew from 10K to nearly 100K followers in three months,
          accumulating 242M+ views, 47M+ accounts reached, 20M+ likes, and a 40%
          increase in engagement. The operational system I designed streamlined
          brand partnerships and enabled 10+ sponsored campaigns. A single viral
          campaign concept generated 33M+ views on its own, becoming one of the
          highest-performing pieces of content on the account.
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .spacer {
    height: 8px;
  }

  /* HERO SECTION */

  #hero {
    display: grid;
    place-items: center;
    padding: 0 3rem;
    margin: auto;
    grid-template-columns: 1fr 1fr;
  }

  .hero--text {
    margin-bottom: 1rem;
  }

  .hero--h1 {
    font-size: 4rem;
    font-family: var(--serif);
    font-weight: 500;
  }

  .hero--h2 {
    margin-bottom: 0.5rem;
    font-size: 2rem;
    font-weight: 200;
  }

  .hero--h3 {
    font-size: 1.5rem;
    text-align: left;
    width: 100%;
    font-weight: 600;
    margin-bottom: 0.75rem;
    font-family: var(--serif);
  }

  .hero--description {
    margin-bottom: 4rem;
  }

  .hero--role-list {
    display: flex;
    flex-direction: row;
    gap: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .hero--role {
    padding: 0.5rem 1rem;
    border-radius: 50rem;
    background-color: rgb(217, 69, 192);
    color: white;
    font-weight: 600;
    font-size: 0.8rem;
  }

  /* Right side hero section */

  .hero--picutre-section {
    outline: 1px solid var(--dark-text);
    background-color: var(--background-color-light);
    margin: 2rem 1rem;
    padding: 1rem;
  }

  .hero--wireframe-wrapper {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    padding: 1rem 0.5rem;
  }

  .hero--wireframe {
    width: 30%;
    height: 12rem;
    object-fit: cover;
    object-position: top;
    margin: auto;
    outline: 1px solid var(--dark-text);
    box-shadow: 2px 2px 1px 1px var(--dark-text);
    border-radius: 1rem;
  }

  .hero--wireframe-text-wrapper {
    margin-top: 0.5rem;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
  }

  .hero--wireframe-description {
    margin-bottom: 2rem;
  }

  .hero--wireframe-button {
    text-align: center;
    margin: auto;
    margin-bottom: 1rem;

    padding: 0.75rem 1.5rem;
    background-color: var(--primary-color);
    color: var(--light-text);
    font-weight: 600;
    font-size: 1rem;
    box-shadow: 2px 2px 1px 1px var(--dark-text);

    border-radius: 1rem;
    transition: 0.1s ease;
  }

  .hero--wireframe-button:hover {
    opacity: 70%;
    cursor: pointer;
  }

  .hero--wireframe-button:active {
    transform: translateY(2px) translateX(2px);
    box-shadow: none;
  }

  .hero--wireframe-button-hollow {
    text-align: center;
    margin: auto;
    margin-bottom: 1rem;
    padding: 0.75rem 1.5rem;
    background-color: var(--background-color-light);
    color: var(--dark-text);
    font-weight: 600;
    font-size: 1rem;
    box-shadow: 2px 2px 1px 1px var(--dark-text);
    outline: 1px solid var(--dark-text);
    border-radius: 1rem;
    transition: 0.1s ease;
  }

  .hero--wireframe-button-hollow:hover {
    opacity: 70%;
    cursor: pointer;
  }

  .hero--wireframe-button-hollow:active {
    transform: translateY(2px) translateX(2px);
    box-shadow: none;
  }

  /* Timeline */

  #timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline--h1 {
    margin-top: 2rem;

    font-size: 3rem;
    font-family: var(--serif);
    font-weight: 500;
  }

  .timeline--hr {
    margin-bottom: 2rem;
  }

  .timeline--wrapper {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    padding: 0 3rem;
  }

  .timeline--card {
    flex: 1;
    background-color: var(--background-color-light);
    padding: 1rem;
    outline: 1px solid var(--dark-text);
    border-radius: 1rem;
  }

  .timeline--card-title {
    font-size: 1.25rem;
    font-weight: 600;
    text-align: center;
    margin-bottom: 0.5rem;
  }

  /* Bottom part */

  .timeline--info {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
    margin-bottom: 3rem;
    width: 100%;
  }

  .timeline--info-text {
    width: 100%;
    max-width: 800px;
  }

  .timeline--h2 {
    margin-bottom: 0.5rem;
    font-size: 2rem;
    font-weight: 200;
  }

  .timeline--button-wrapper {
    display: flex;
    flex-direction: column;
  }

  .timeline-description {
    font-size: 1.15rem;
  }

  .hero--stats-wrapper {
    display: flex;
    flex-direction: row;
    justify-content: space-around;
    padding: 0.5rem 0 1rem;
  }

  .hero--stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .hero--stat-number {
    font-size: 1.75rem;
    font-family: var(--serif);
    font-weight: 600;
  }

  .hero--stat-label {
    font-size: 0.8rem;
    font-weight: 400;
    text-align: center;
  }

  @media (max-width: 768px) {
    #hero {
      grid-template-columns: 1fr;
      padding: 0 1rem;
    }

    .hero--h1 {
      font-size: 2.5rem;
    }

    .hero--h2 {
      font-size: 1.5rem;
    }

    .hero--role-list {
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .hero--wireframe-wrapper {
      flex-direction: column;
      gap: 1rem;
    }

    .hero--wireframe {
      width: 100%;
      max-width: 320px;
      margin: auto;
    }

    .hero--stats-wrapper {
      flex-direction: column;
      gap: 1rem;
    }

    #timeline .timeline--wrapper {
      flex-direction: column;
      padding: 0 1rem;
    }

    .timeline--info {
      flex-direction: column;
      align-items: flex-start;
      padding: 0 1rem;
    }

    .timeline--h1 {
      font-size: 2.5rem;
    }

    .timeline--h2 {
      font-size: 1.5rem;
    }
  }
</style>

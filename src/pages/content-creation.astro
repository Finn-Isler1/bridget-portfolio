---
import Layout from "../layouts/Layout.astro";
import WorkNav from "../components/WorkNav.astro";

const title = "work";

const videos = [
  {
    title: "Red Cup Day",
    description: "@bridgetthebarista",
    views: "841.7K views",
    src: "/bridget-portfolio/videos/v12300gd0001d4ag7kfog65rp8c3105g.mp4",
    tiktok: "https://www.tiktok.com/t/ZThnvV3LT/",
  },
  {
    title: "Brown Sugar Foam",
    description: "@starbucks",
    views: "266.7K views",
    src: "/bridget-portfolio/videos/v12025gd0000d0f5i3vog65r25d3e810.mp4",
    tiktok: "https://www.tiktok.com/t/ZThnvVg76/",
  },
  {
    title: "Red Apron Hype",
    description: "@starbuckspartners",
    views: "20.8K views",
    src: "/bridget-portfolio/videos/v15044gf0000d4afkcfog65r962844ng.mp4",
    tiktok: "https://www.tiktok.com/t/ZThnvnBm5/",
  },
  {
    title: "Eggnog Is Back",
    description: "@bridgetthebarista",
    views: "",
    src: "/bridget-portfolio/videos/v12300gd0001d4nkc67og65kk9cd220g.mp4",
    tiktok: "https://www.tiktok.com/t/ZThnvuHCM/",
  },
  {
    title: "Apple is Back",
    description: "@bridgetthebarista",
    views: "",
    src: "/bridget-portfolio/videos/v12300gd0001d3jb7kfog65osju6uppg.mp4",
    tiktok: "https://www.tiktok.com/t/ZThnvtHxX/",
  },
];
---

<Layout>
  <div class="spacer"></div>
  <WorkNav />

  <section id="content-creation">
    <h1>CONTENT CREATION</h1>

    <div class="video-grid">
      {
        videos.map((video, index) => (
          <div class="video-card">
            <div class="phone-frame" data-video={video.src}>
              <video
                class="preview-video"
                src={video.src}
                muted
                loop
                autoplay
                playsinline
              />
            </div>

            <div class="video-info">
              <h2 class="video-title">{video.title}</h2>

              <p class="video-description">{video.description}</p>

              <p class="video-views">{video.views || "\u00A0"}</p>

              <a class="video-link" href={video.tiktok} target="_blank">
                Watch on TikTok
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </section>
  <section id="text">
    <section id="article">
      <div class="article--wrapper">
        <h1 class="article--h1">Featured Recognition</h1>

        <hr />
        <p class="article--description">
          Recognized by <i>The Wall Street Journal</i> for high-performing digital
          content, featured in coverage mentioned on <i
            >The Tonight Show Starring Jimmy Fallon</i
          >.
        </p>

        <div class="article--link-container">
          <div class="article--item">
            <a
              class="article--link"
              target="_blank"
              href="https://www.wsj.com/lifestyle/workplace/the-new-in-demand-job-skill-being-a-tiktok-influencer-for-your-company-9ca9d232?gaa_at=eafs&gaa_n=AWEtsqevFfYk6nPfLTpv5geYxBbBR8y2gcdNrxL17Ro0G7VIgRJ3FW9o80K9KPlE4dU%3D&gaa_ts=69a4b9c1&gaa_sig=s4lpq9I3Yb1V7yShpMc2iNeD1W1sWPpnZDJN1cruhirwgA2Y9_cZPkaT78STj8NWT_t3_W3m4UDygqaNjKI8gw%3D%3D"
              ><img
                class="article--image"
                src="/bridget-portfolio/assets/WSJ-4.jpg"
              /></a
            >
            <p class="article--label">WSJ Article</p>
            <a
              class="article--button"
              target="_blank"
              href="https://www.wsj.com/lifestyle/workplace/the-new-in-demand-job-skill-being-a-tiktok-influencer-for-your-company-9ca9d232?gaa_at=eafs&gaa_n=AWEtsqevFfYk6nPfLTpv5geYxBbBR8y2gcdNrxL17Ro0G7VIgRJ3FW9o80K9KPlE4dU%3D&gaa_ts=69a4b9c1&gaa_sig=s4lpq9I3Yb1V7yShpMc2iNeD1W1sWPpnZDJN1cruhirwgA2Y9_cZPkaT78STj8NWT_t3_W3m4UDygqaNjKI8gw%3D%3D"
              >Read the article</a
            >
          </div>

          <div class="article--item">
            <a
              class="article--link"
              target="_blank"
              href="https://www.wsj.com/video/series/on-the-news/companies-are-creating-their-own-influencer-programs/EFD2A01B-E1C7-45FB-941F-9B0D019E2A97"
              ><img
                class="article--image"
                src="/bridget-portfolio/assets/WSJ-3.jpg"
              /></a
            >
            <p class="article--label">WSJ Video</p>
            <a
              class="article--button"
              target="_blank"
              href="https://www.wsj.com/video/series/on-the-news/companies-are-creating-their-own-influencer-programs/EFD2A01B-E1C7-45FB-941F-9B0D019E2A97"
              >Watch the video</a
            >
          </div>

          <div class="article--item">
            <a
              class="article--link"
              target="_blank"
              href="https://youtu.be/WV9RuwT7Svg"
              ><img
                class="article--image"
                src="/bridget-portfolio/assets/jimmy-fallon.jpg"
              /></a
            >
            <p class="article--label">Tonight Show Clip</p>
            <a
              class="article--button"
              target="_blank"
              href="https://youtu.be/WV9RuwT7Svg">View the clip</a
            >
          </div>
        </div>

        <p class="gac-recognition-description">
          Green Apron Creator Program Recognition
        </p>
        <!-- NEW FEATURED IMAGE -->
        <div class="article--featured-image">
          <img
            class="gac-pilot-image"
            src="/bridget-portfolio/thumb/green-apron-pilot.PNG"
            alt="Green Apron Creator Program Recognition"
          />
          <p class="article--featured-caption">
            Recognized as one of the pilot creators for the Green Apron Creator
            Program’s success at the Starbucks Leadership Experience 2025.
          </p>
        </div>
      </div>
    </section>

    <div class="text-wrapper">
      <h1 class="content-header">About My Content</h1>
      <p>
        I create short-form video content centered around authentic
        behind-the-scenes moments as a Starbucks barista. My content focuses on
        storytelling, humor, and everyday experiences that resonate with both
        customers and partners.
      </p>
      <p>
        I have been part of the Starbucks Green Apron Creator program for over a
        year, beginning in the original pilot team of eight creators. Through
        this program, I completed multiple training and mentorship programs
        focused on content strategy, brand storytelling, and responsible digital
        creation.
      </p>
      <p>
        My work has been recognized internally and externally, including being
        highlighted at the Starbucks Leadership Experience 2025 for successful
        creator content. I also produce training videos designed to help new
        creators understand topics such as content strategy, copyright, and
        brand-safe storytelling.
      </p>
    </div>
  </section>

  <div id="videoModal" class="modal">
    <span class="close" onclick="closeModal()">&times;</span>

    <video id="modalVideo" controls preload="metadata" playsinline>
      Your browser does not support HTML5 video.
    </video>
  </div>
</Layout>

<style>
  .text-wrapper {
    margin-top: 1rem;
    font-size: 1.25rem;
    line-height: 1.5rem;
    padding: 1rem 1.5rem;
    margin: auto;
    outline: 2px solid var(--dark-text);
    background-color: var(--background-color-light);
    max-width: 800px;
  }

  .content-header {
    text-align: center;
    margin-top: 1.5rem;
  }

  .text-wrapper p {
    margin-bottom: 1rem;
  }
  .spacer {
    height: 8px;
  }

  #text {
    padding-bottom: 2rem;
  }

  #content-creation {
    max-width: 1200px;
    margin: auto;
    padding: 2rem;
    text-align: center;
  }

  h1 {
    font-family: "Times New Roman", serif;
    font-size: 3rem;
    margin-bottom: 3rem;
  }

  .video-grid {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .video-card {
    width: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .phone-frame {
    width: 200px;
    height: 380px;
    border: 2px solid black;
    border-radius: 2rem;
    overflow: hidden;
    cursor: pointer;
    transition: 0.2s;
  }

  .phone-frame:hover {
    transform: scale(1.05);
  }

  .preview-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-info {
    text-align: center;
    margin-top: 0.5rem;
  }

  .video-title {
    font-family: "Times New Roman", serif;
    font-weight: bold;
    font-size: 1.2rem;
  }

  .video-description {
    color: #777;
    font-size: 0.95rem;
  }

  .video-views {
    color: #999;
    font-size: 0.9rem;
  }

  .hero--wireframe-button {
    text-align: center;
    margin: auto;
    margin-bottom: 1rem;

    padding: 0.75rem 1.5rem;
    background-color: var(--primary-color);
    color: var(--light-text);
    font-weight: 600;
    font-size: 1rem;
    box-shadow: 2px 2px 1px 1px var(--dark-text);

    border-radius: 1rem;
    transition: 0.1s ease;
  }

  /* .hero--wireframe-button:hover {
    opacity: 70%;
    cursor: pointer;
  }

 */

  .video-link,
  .article--button {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.4rem 0.9rem;
    padding: 0.75rem 1.5rem;
    background-color: var(--primary-color);
    color: var(--light-text);
    font-weight: 600;
    font-size: 1rem;
    box-shadow: 2px 2px 1px 1px var(--dark-text);
    border-radius: 1rem;
    transition: 0.1s ease;
  }

  .video-link:hover,
  .article--button:hover {
    opacity: 70%;
    cursor: pointer;
  }

  .video-link:active,
  .article--button:active {
    transform: translateY(2px) translateX(2px);
    box-shadow: none;
  }

  .modal {
    display: none;
    position: fixed;
    z-index: 999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    justify-content: center;
    align-items: center;
  }

  .modal video {
    max-height: 80%;
    border-radius: 1rem;
  }

  .close {
    position: absolute;
    top: 30px;
    right: 40px;
    font-size: 40px;
    color: white;
    cursor: pointer;
  }

  /* featured-recognition.css */

  /* SECTION STYLING */
  #article {
    padding: 2rem 1.5rem;
    max-width: 1000px;
    margin: 3rem auto 3rem auto;
    outline: 2px solid var(--dark-text);
    background-color: var(--background-color-light);
  }

  .article--wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .article--h1 {
    font-family: var(--serif);
    font-size: 3rem;
    text-align: center;
    margin-bottom: 1rem;
  }

  .article--description {
    font-size: 1.25rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  /* LINK GRID */
  .article--link-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
    width: 100%;
    justify-items: center;
  }

  /* INDIVIDUAL ITEM */
  .article--item {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  /* IMAGE LINK */
  .article--link {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    border-radius: 1.5rem;
    overflow: hidden;
    transition: 0.2s ease;
  }

  .article--link:hover {
    opacity: 0.7;
  }

  .article--image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 1.5rem;
  }

  /* LABEL ABOVE BUTTON */
  .article--label {
    margin: 0.5rem 0 0.5rem 0;
    font-size: 1rem;
    font-weight: 600;
    text-align: center;
  }

  /* BUTTON STYLING */
  /* .article--button {
    margin-top: 0.5rem;
    padding: 0.75rem 1.5rem;
    background-color: var(--primary-color);
    color: var(--light-text);
    font-weight: 600;
    font-size: 1rem;
    text-align: center;
    border-radius: 1rem;
    text-decoration: none;
    transition: 0.1s ease;
    width: 40%;
  }

  .article--button:hover {
    opacity: 0.7;
  }

  .article--button:active {
    transform: translateY(2px) translateX(2px);
    box-shadow: none;
  } */

  /* RESPONSIVE ADJUSTMENTS */
  @media (max-width: 768px) {
    .article--link-container {
      grid-template-columns: 1fr;
    }

    .article--image {
      height: 180px;
    }
  }

  .gac-recognition-description {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 600;
    text-align: center;
    letter-spacing: 0.02em;
  }

  .gac-recognition-description::before {
    content: "";
    display: block;
    width: 110px;
    height: 2px;
    margin: 0.6rem auto 1rem auto;
    background-color: var(--dark-text);
  }
  /* Featured single landscape image */
  .article--featured-image {
    margin-top: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .article--featured-image img {
    width: 100%;
    max-width: 900px; /* adjust based on design */
    border-radius: 1.5rem;
    object-fit: cover;
    height: auto;
  }

  .article--featured-image .gac-pilot-image {
    width: 75%;
  }

  .article--featured-caption {
    width: 75%;
    margin: auto;
    margin-top: 1rem;
    font-size: 1rem;
    text-align: left;
    max-width: 900px;
    line-height: 1.4rem;
  }

  i {
    font-style: italic;
  }
</style>

<script>
  const modalPlayer = document.getElementById("modalVideo");
  if (modalPlayer) {
    modalPlayer.addEventListener("error", () => {
      console.error("Video failed to load:", modalPlayer.error);
    });
  }

  /**
   * Get the configured video src for a given card index.
   * This keeps the modal synced with the rendered list.
   */
  function getVideoSrcForIndex(index) {
    const frame = document.querySelectorAll(".phone-frame")[index];
    return frame?.dataset?.video ?? "";
  }

  // attach click listeners to every video card
  document.querySelectorAll(".phone-frame").forEach((frame, index) => {
    frame.addEventListener("click", () => {
      openModal(index);
    });
  });

  function openModal(index) {
    const modal = document.getElementById("videoModal");
    const player = document.getElementById("modalVideo");

    const src = getVideoSrcForIndex(index);
    if (!src) {
      console.error("No video source found for index", index);
      return;
    }

    player.src = src;
    player?.load();

    modal.style.display = "flex";

    player.play().catch((err) => {
      // Autoplay might be blocked; user can press play manually.
      console.warn("Video playback prevented:", err);
    });
  }

  function closeModal() {
    const modal = document.getElementById("videoModal");
    const player = document.getElementById("modalVideo");

    player.pause();
    modal.style.display = "none";
  }

  // Close modal when clicking outside the video
  document.getElementById("videoModal").addEventListener("click", (e) => {
    if (e.target.id === "videoModal") {
      closeModal();
    }
  });
</script>

---
import Layout from "../layouts/Layout.astro";
import WorkNav from "../components/WorkNav.astro";

const title = "work";

const videos = [
  {
    title: "Red Cup Day",
    description: "@bridgetthebarista",
    views: "841.7K views",
    src: "/bridget-portfolio/videos/v12300gd0001d4ag7kfog65rp8c3105g.mp4",
    tiktok: "https://www.tiktok.com/t/ZThnvV3LT/",
  },
  {
    title: "Brown Sugar Foam",
    description: "@starbucks",
    views: "266.7K views",
    src: "/bridget-portfolio/videos/v12025gd0000d0f5i3vog65r25d3e810.mp4",
    tiktok: "https://www.tiktok.com/t/ZThnvVg76/",
  },
  {
    title: "Red Apron Hype",
    description: "@starbuckspartners",
    views: "20.8K views",
    src: "/bridget-portfolio/videos/v15044gf0000d4afkcfog65r962844ng.mp4",
    tiktok: "https://www.tiktok.com/t/ZThnvnBm5/",
  },
  {
    title: "Eggnog Is Back",
    description: "@bridgetthebarista",
    views: "",
    src: "/bridget-portfolio/videos/v12300gd0001d4nkc67og65kk9cd220g.mp4",
    tiktok: "https://www.tiktok.com/t/ZThnvuHCM/",
  },
  {
    title: "Apple is Back",
    description: "@bridgetthebarista",
    views: "",
    src: "/bridget-portfolio/videos/v12300gd0001d3jb7kfog65osju6uppg.mp4",
    tiktok: "https://www.tiktok.com/t/ZThnvtHxX/",
  },
];
---

<Layout>
  <div class="spacer"></div>
  <WorkNav />

  <section id="content-creation">
   <h1 class="hero--h1">Green Apron Creator Program</h1>
      <h2 class="hero--h2">Content Creator</h2>

    <div class="video-grid">
      {
        videos.map((video, index) => (
          <div class="video-card">
            <div class="phone-frame" data-video={video.src}>
              <video
                class="preview-video"
                src={video.src}
                muted
                loop
                playsinline
                preload="auto"
              />
            </div>

            <div class="video-info">
              <h2 class="video-title">{video.title}</h2>

              <p class="video-description">{video.description}</p>

              <p class="video-views">{video.views || "\u00A0"}</p>

              <a class="video-link" href={video.tiktok} target="_blank">
                Watch on TikTok
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </section>
<section id="text">
  <div class="case-study--hero">
    <div class="case-study--left">
      <h2 class="case-study--h2">Employee-Driven Social Content</h2>
      <h3 class="case-study--h3">Starbucks Green Apron Creator Program</h3>
      <p>Short-form video content highlighting employee experiences, product moments, and training culture to support brand awareness and authentic storytelling at scale.</p>
      <p>Translated high-level brand briefs into fully developed video concepts—written, filmed, edited, and published independently—optimized for short-form engagement and shareability.</p>
      <p class="case-study--roles-label">My Roles:</p>
      <div class="case-study--roles">
        <span class="case-study--role">Content Strategy</span>
        <span class="case-study--role">Video Production</span>
        <span class="case-study--role">Brand Storytelling</span>
        <span class="case-study--role">Training Content</span>
      </div>
    </div>
    <div class="case-study--right">
      <div class="case-study--stats">
        <div class="case-study--stat">
          <span class="case-study--stat-number">840K</span>
          <span class="case-study--stat-label">Top Video Views</span>
        </div>
        <div class="case-study--stat">
          <span class="case-study--stat-number">12K</span>
          <span class="case-study--stat-label">Shares</span>
        </div>
        <div class="case-study--stat">
          <span class="case-study--stat-number">#1</span>
          <span class="case-study--stat-label">of 49 Creators</span>
        </div>
      </div>
      <hr class="case-study--divider" />
      <p>Part of the original pilot team of eight creators in the Starbucks Green Apron Creator Program. Recognized at the Starbucks Leadership Experience 2025 and featured in <i>The Wall Street Journal</i> and <i>The Tonight Show Starring Jimmy Fallon</i>.</p>
    </div>
  </div>

  <hr />

  <div class="case-study--process">
    <h1 class="case-study--process-h1">Process</h1>
    <hr class="case-study--process-hr" />
    <div class="process--cards">
      <div class="process--card">
        <p class="process--card-title">Creative Direction</p>
        <p class="process--card-desc">Developed original video concepts from high-level campaign briefs, translating brand goals into relatable storytelling angles.</p>
      </div>
      <div class="process--card">
        <p class="process--card-title">Script & Story Structure</p>
        <p class="process--card-desc">Wrote concepts and scripts with clear hooks, narrative beats, and payoffs optimized for short-form retention.</p>
      </div>
      <div class="process--card">
        <p class="process--card-title">Independent Production</p>
        <p class="process--card-desc">Filmed and edited each video independently using iPhone, tripod, CapCut, Adobe tools, and in-app editing.</p>
      </div>
      <div class="process--card">
        <p class="process--card-title">Format Diversity</p>
        <p class="process--card-desc">Produced across day-in-the-life, seasonal promotions, product highlights, and internal training content formats.</p>
      </div>
      <div class="process--card">
        <p class="process--card-title">Campaign Alignment</p>
        <p class="process--card-desc">Coordinated content timing with product launches like Red Cup Day and seasonal promotions for maximum visibility.</p>
      </div>
      <div class="process--card">
        <p class="process--card-title">Creator Training</p>
        <p class="process--card-desc">Produced training videos for 40 new creators covering content strategy, copyright, and brand-safe storytelling.</p>
      </div>
    </div>
    <div class="case-study--impact">
      <div class="case-study--impact-text">
        <h2 class="case-study--impact-h2">Impact & Outcome</h2>
        <p class="case-study--impact-desc">Authentic, employee-led storytelling consistently outperformed traditional promotional content. The highest-performing video reached 840K views, 12K shares, 24K likes, and 4K saves. A second top video achieved 250K views with strong customer engagement. Content increased visibility for seasonal campaigns like Red Cup Day and earned external recognition in <i>The Wall Street Journal</i>—demonstrating the power of relatable, human-centered marketing in driving engagement and brand connection.</p>
      </div>
    </div>
  </div>


    <section id="article">
      <div class="article--wrapper">
        <h1 class="article--h1">Featured Recognition</h1>

        <hr />
        <p class="article--description">
          Recognized by <i>The Wall Street Journal</i> for high-performing digital
          content, featured in coverage mentioned on <i
            >The Tonight Show Starring Jimmy Fallon</i
          >.
        </p>

        <div class="article--link-container">
          <div class="article--item">
            <a
              class="article--link"
              target="_blank"
              href="https://www.wsj.com/lifestyle/workplace/the-new-in-demand-job-skill-being-a-tiktok-influencer-for-your-company-9ca9d232?gaa_at=eafs&gaa_n=AWEtsqevFfYk6nPfLTpv5geYxBbBR8y2gcdNrxL17Ro0G7VIgRJ3FW9o80K9KPlE4dU%3D&gaa_ts=69a4b9c1&gaa_sig=s4lpq9I3Yb1V7yShpMc2iNeD1W1sWPpnZDJN1cruhirwgA2Y9_cZPkaT78STj8NWT_t3_W3m4UDygqaNjKI8gw%3D%3D"
              ><img
                class="article--image"
                src="/bridget-portfolio/thumb/wsj-article.png"
              /></a
            >
            <p class="article--label">WSJ Article</p>
            <a
              class="article--button"
              target="_blank"
              href="https://www.wsj.com/lifestyle/workplace/the-new-in-demand-job-skill-being-a-tiktok-influencer-for-your-company-9ca9d232?gaa_at=eafs&gaa_n=AWEtsqevFfYk6nPfLTpv5geYxBbBR8y2gcdNrxL17Ro0G7VIgRJ3FW9o80K9KPlE4dU%3D&gaa_ts=69a4b9c1&gaa_sig=s4lpq9I3Yb1V7yShpMc2iNeD1W1sWPpnZDJN1cruhirwgA2Y9_cZPkaT78STj8NWT_t3_W3m4UDygqaNjKI8gw%3D%3D"
              >Read the article</a
            >
          </div>

          <div class="article--item">
            <a
              class="article--link"
              target="_blank"
              href="https://www.wsj.com/video/series/on-the-news/companies-are-creating-their-own-influencer-programs/EFD2A01B-E1C7-45FB-941F-9B0D019E2A97"
              ><img
                class="article--image"
                src="/bridget-portfolio/assets/wsj-video.png"
              /></a
            >
            <p class="article--label">WSJ Video</p>
            <a
              class="article--button"
              target="_blank"
              href="https://www.wsj.com/video/series/on-the-news/companies-are-creating-their-own-influencer-programs/EFD2A01B-E1C7-45FB-941F-9B0D019E2A97"
              >Watch the video</a
            >
          </div>

          <div class="article--item">
            <a
              class="article--link"
              target="_blank"
              href="https://youtu.be/WV9RuwT7Svg"
              ><img
                class="article--image"
                src="/bridget-portfolio/assets/jimmy-fallon.jpg"
              /></a
            >
            <p class="article--label">Tonight Show Clip</p>
            <a
              class="article--button"
              target="_blank"
              href="https://youtu.be/WV9RuwT7Svg">View the clip</a
            >
          </div>
        </div>

        <p class="gac-recognition-description">
          Green Apron Creator Program Recognition
        </p>
<!-- NEW FEATURED IMAGE -->
<div class="gac-image-row">
  <div class="gac-image-item">
    <img
      class="gac-pilot-image"
      src="/bridget-portfolio/thumb/green-apron-pilot.PNG"
      alt="Green Apron Creator Program Recognition"
    />
    <p class="article--featured-caption">
      Recognized at the Starbucks Leadership Experience
      2025 as one of the pilot creators for the Green Apron
      Creator Program's success.
    </p>
  </div>
  <div class="gac-image-item gac-image-narrow">
    <img
      src="/bridget-portfolio/assets/number-one.jpg"
      alt="Ranked #1 Creator"
    />
    <p class="article--featured-caption">
      Ranked <b>#1 out of 49 creators</b> in the Green Apron Creator Program
      based on internal performance metrics.
    </p>
  </div>
</div>

<div class="gac-image-full">
  <img
    src="/bridget-portfolio/assets/rec.png"
    alt="LinkedIn Recommendation"
  />
</div>
      </div>
    </section>
  </section>

  <div id="videoModal" class="modal">
    <span class="close" onclick="closeModal()">&times;</span>

    <video id="modalVideo" controls preload="metadata" playsinline>
      Your browser does not support HTML5 video.
    </video>
  </div>
</Layout>

<style>
  /* Case Study Hero */
.case-study--hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  max-width: 1000px;
  margin: 2rem auto;
  padding: 0 1.5rem;
  align-items: start;
}

.case-study--h2 {
  font-family: var(--serif);
  font-size: 2.2rem;
  font-weight: 500;
  margin-bottom: 0.5rem;
}

.case-study--h3 {
  font-size: 1.25rem;
  font-weight: 200;
  margin-bottom: 1.5rem;
}

.case-study--left p {
  font-size: 1.1rem;
  line-height: 1.6rem;
  margin-bottom: 1rem;
}

.case-study--roles-label {
  font-size: 1.1rem;
  font-weight: 600;
  font-family: var(--serif);
  margin-bottom: 0.5rem;
}

.case-study--roles {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.case-study--role {
  padding: 0.4rem 1rem;
  border-radius: 50rem;
  background-color: var(--primary-color);
  color: var(--light-text);
  font-weight: 600;
  font-size: 0.8rem;
}

.case-study--right {
  outline: 1px solid var(--dark-text);
  background-color: var(--background-color-light);
  padding: 1.5rem;
}

.case-study--right p {
  font-size: 1rem;
  line-height: 1.55rem;
}

.case-study--stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 1.5rem;
}

.case-study--stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
}

.case-study--stat-number {
  font-family: var(--serif);
  font-size: 1.75rem;
  font-weight: 600;
}

.case-study--stat-label {
  font-size: 0.75rem;
  text-align: center;
}

.case-study--divider {
  margin: 1rem 0;
}

/* Process */
.case-study--process {
  max-width: 1000px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

.case-study--process-h1 {
  margin-top: 2rem;
  font-size: 3rem;
  font-family: var(--serif);
  font-weight: 500;
}

.case-study--process-hr {
  margin-bottom: 2rem;
}

.process--cards {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
}

.process--card {
  flex: 1 1 calc(33% - 1rem);
  background-color: var(--background-color-light);
  padding: 1rem;
  outline: 1px solid var(--dark-text);
  border-radius: 1rem;
}

.process--card-title {
  font-size: 1.1rem;
  font-weight: 600;
  text-align: center;
  margin-bottom: 0.4rem;
}

.process--card-desc {
  font-size: 0.95rem;
  line-height: 1.4rem;
}
.gac-image-full {
  display: flex;
  justify-content: center;
  width: 100%;
  margin-top: 1.5rem;
}

.gac-image-full img {
  width: 92%;
  border-radius: 1.5rem;
  object-fit: cover;
}

@media (max-width: 768px) {
  .gac-image-full img {
    width: 100%;
  }
}
/* Impact */
.case-study--impact {
  display: flex;
  justify-content: center;
  margin-top: 2rem;
  margin-bottom: 3rem;
}

.case-study--impact-text {
  width: 100%;
  max-width: 800px;
}

.case-study--impact-h2 {
  font-size: 2rem;
  font-weight: 200;
  margin-bottom: 0.5rem;
}

.case-study--impact-desc {
  font-size: 1.15rem;
  line-height: 1.7rem;
}

@media (max-width: 768px) {
  .case-study--hero {
    grid-template-columns: 1fr;
  }
  .process--card {
    flex: 1 1 100%;
  }
}
  
  .text-wrapper {
    margin-top: 1rem;
    font-size: 1.25rem;
    line-height: 1.5rem;
    padding: 1rem 1.5rem;
    margin: auto;
    outline: 2px solid var(--dark-text);
    background-color: var(--background-color-light);
    max-width: 1000px;
  }

  .content-header {
    text-align: center;
    margin-top: 1.5rem;
  }

  .text-wrapper p {
    margin-bottom: 1rem;
  }
  .spacer {
    height: 8px;
  }

  #text {
    padding-bottom: 2rem;
  }

  #content-creation {
    max-width: 1200px;
    margin: auto;
    padding: 2rem;
    text-align: center;
  }

  h1 {
    font-family: "Times New Roman", serif;
    font-size: 3rem;
    margin-bottom: 3rem;
  }

   .hero--h1 {
    font-size: 4rem;
    font-family: var(--serif);
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .hero--h2 {
    margin-bottom: 2rem;
    font-size: 2rem;
    font-weight: 200;
  }

  .video-grid {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .video-card {
    width: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .phone-frame {
    width: 200px;
    height: 380px;
    border: 2px solid black;
    border-radius: 2rem;
    overflow: hidden;
    cursor: pointer;
    transition: 0.2s;
    background-color: #000;
  }

  .phone-frame:hover {
    transform: scale(1.05);
  }

  .preview-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    display: block;
    background-color: #000;
    will-change: transform, opacity;
  }

  /* Ensure video container is always visible */
  .phone-frame video {
    opacity: 1;
    visibility: visible;
    transform: translateZ(0);
  }

  /* Prevent any hover-based transform conflicts */
  .phone-frame {
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  .video-info {
    text-align: center;
    margin-top: 0.5rem;
  }

  .video-title {
    font-family: "Times New Roman", serif;
    font-weight: bold;
    font-size: 1.2rem;
  }

  .video-description {
    color: #777;
    font-size: 0.95rem;
  }

  .video-views {
    color: #999;
    font-size: 0.9rem;
  }

  .hero--wireframe-button {
    text-align: center;
    margin: auto;
    margin-bottom: 1rem;

    padding: 0.75rem 1.5rem;
    background-color: var(--primary-color);
    color: var(--light-text);
    font-weight: 600;
    font-size: 1rem;
    box-shadow: 2px 2px 1px 1px var(--dark-text);

    border-radius: 1rem;
    transition: 0.1s ease;
  }

  /* .hero--wireframe-button:hover {
    opacity: 70%;
    cursor: pointer;
  }

 */

  .video-link,
  .article--button {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.4rem 0.9rem;
    padding: 0.75rem 1.5rem;
    background-color: var(--primary-color);
    color: var(--light-text);
    font-weight: 600;
    font-size: 1rem;
    box-shadow: 2px 2px 1px 1px var(--dark-text);
    border-radius: 1rem;
    transition: 0.1s ease;
  }

  .video-link:hover,
  .article--button:hover {
    opacity: 70%;
    cursor: pointer;
  }

  .video-link:active,
  .article--button:active {
    transform: translateY(2px) translateX(2px);
    box-shadow: none;
  }

  .modal {
    display: none;
    position: fixed;
    z-index: 999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    justify-content: center;
    align-items: center;
  }

  .modal video {
    max-height: 80%;
    border-radius: 1rem;
  }

  .close {
    position: absolute;
    top: 30px;
    right: 40px;
    font-size: 40px;
    color: white;
    cursor: pointer;
  }

  /* featured-recognition.css */

  /* SECTION STYLING */
  #article {
    padding: 2rem 1.5rem;
    max-width: 1000px;
    margin: 3rem auto 3rem auto;
    outline: 2px solid var(--dark-text);
    background-color: var(--background-color-light);
  }

  .article--wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .article--h1 {
    font-family: var(--serif);
    font-size: 3rem;
    text-align: center;
    margin-bottom: 1rem;
  }

  .article--description {
    font-size: 1.25rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  /* LINK GRID */
  .article--link-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
    width: 100%;
    justify-items: center;
  }

  /* INDIVIDUAL ITEM */
  .article--item {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  /* IMAGE LINK */
  .article--link {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    border-radius: 1.5rem;
    overflow: hidden;
    transition: 0.2s ease;
  }

  .article--link:hover {
    opacity: 0.7;
  }

  .article--image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 1.5rem;
  }

  /* LABEL ABOVE BUTTON */
  .article--label {
    margin: 0.5rem 0 0.5rem 0;
    font-size: 1rem;
    font-weight: 600;
    text-align: center;
  }

  /* BUTTON STYLING */
  /* .article--button {
    margin-top: 0.5rem;
    padding: 0.75rem 1.5rem;
    background-color: var(--primary-color);
    color: var(--light-text);
    font-weight: 600;
    font-size: 1rem;
    text-align: center;
    border-radius: 1rem;
    text-decoration: none;
    transition: 0.1s ease;
    width: 40%;
  }

  .article--button:hover {
    opacity: 0.7;
  }

  .article--button:active {
    transform: translateY(2px) translateX(2px);
    box-shadow: none;
  } */

  /* RESPONSIVE ADJUSTMENTS */
  @media (max-width: 768px) {
    .article--link-container {
      grid-template-columns: 1fr;
    }

    .article--image {
      height: 180px;
    }
  }

  .gac-recognition-description {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 600;
    text-align: center;
    letter-spacing: 0.02em;
  }

  .gac-recognition-description::before {
    content: "";
    display: block;
    width: 110px;
    height: 2px;
    margin: 0.6rem auto 1rem auto;
    background-color: var(--dark-text);
  }
  /* Featured single landscape image */
  .article--featured-image {
    margin-top: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .article--featured-image img {
    width: 100%;
    max-width: 900px; /* adjust based on design */
    border-radius: 1.5rem;
    object-fit: cover;
    height: auto;
  }

  .article--featured-image .gac-pilot-image {
    width: 75%;
  }

  /* Green Apron recognition image row */
  .gac-image-row {
    display: flex;
    gap: 2rem;
    justify-content: center;
    align-items: flex-start;
    width: 100%;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  /* individual image block */
  .gac-image-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 60%;
    max-width: 600px;
  }

  /* narrow image */
  .gac-image-narrow {
    width: 30%;
    max-width: 280px;
  }

  .gac-image-item img {
    width: 100%;
    border-radius: 1.5rem;
    object-fit: cover;
  }

  /* caption alignment */
  .gac-image-item .article--featured-caption {
    width: 100%;
    margin-top: 0.75rem;
    font-size: 1rem;
    line-height: 1.4rem;
  }

  .article--featured-caption {
    width: 75%;
    margin: auto;
    margin-top: 1rem;
    font-size: 1rem;
    text-align: left;
    max-width: 900px;
    line-height: 1.4rem;
  }

  i {
    font-style: italic;
  }

  @media (max-width: 768px) {
    #content-creation {
      padding: 1rem;
    }

    h1 {
      font-size: 2.5rem;
    }

    .video-grid {
      gap: 1rem;
    }

    .video-card {
      width: 100%;
      max-width: 360px;
    }

    .phone-frame {
      width: 100%;
      max-width: 360px;
      height: auto;
      aspect-ratio: 9 / 16;
    }

    .modal video {
      width: 90%;
      max-width: 600px;
    }

    .gac-image-row {
      flex-direction: column;
      gap: 1.5rem;
    }

    .gac-image-item {
      width: 100%;
      max-width: 600px;
    }
  }
</style>

<script>
  // Robust video handling to prevent glitching
  function initVideo(video: HTMLVideoElement) {
    // Ensure video is ready
    video.preload = "auto";
    
    const playVideo = () => {
      if (video.paused) {
        video.play().catch(() => {});
      }
    };

    // Wait for video to be ready before playing
    if (video.readyState >= 2) {
      playVideo();
    } else {
      video.addEventListener("canplay", playVideo, { once: true });
    }
    
    video.addEventListener("stalled", () => {
      video.load();
    });
    
    video.addEventListener("error", () => {
      video.load();
    });
  }

  // Initialize all preview videos
  document.querySelectorAll(".preview-video").forEach((video) => {
    initVideo(video as HTMLVideoElement);
  });

  // Handle hover states to ensure videos play consistently
  document.querySelectorAll(".phone-frame").forEach((frame) => {
    const video = frame.querySelector(".preview-video") as HTMLVideoElement | null;
    if (!video) return;

    frame.addEventListener("mouseenter", () => {
      if (video.paused) {
        video.play().catch(() => {});
      }
    });
  });

  const modalPlayer = document.getElementById("modalVideo") as HTMLVideoElement | null;
  if (modalPlayer) {
    modalPlayer.addEventListener("error", () => {
      console.error("Video failed to load:", modalPlayer.error);
    });
  }

  /**
   * Get the configured video src for a given card index.
   * This keeps the modal synced with the rendered list.
   */
  function getVideoSrcForIndex(index: number): string {
    const frame = document.querySelectorAll(".phone-frame")[index] as HTMLElement | undefined;
    return frame?.dataset?.video ?? "";
  }

  // attach click listeners to every video card
  document.querySelectorAll(".phone-frame").forEach((frame, index) => {
    frame.addEventListener("click", () => {
      openModal(index);
    });
  });

  function openModal(index: number): void {
    const modal = document.getElementById("videoModal") as HTMLElement | null;
    const player = document.getElementById("modalVideo") as HTMLVideoElement | null;

    if (!modal || !player) {
      console.error("Modal or player element not found");
      return;
    }

    const src = getVideoSrcForIndex(index);
    if (!src) {
      console.error("No video source found for index", index);
      return;
    }

    player.src = src;
    player.load();

    modal.style.display = "flex";

    player.play().catch((err: Error) => {
      // Autoplay might be blocked; user can press play manually.
      console.warn("Video playback prevented:", err);
    });
  }

  function closeModal(): void {
    const modal = document.getElementById("videoModal") as HTMLElement | null;
    const player = document.getElementById("modalVideo") as HTMLVideoElement | null;

    if (!modal || !player) {
      return;
    }

    player.pause();
    modal.style.display = "none";
  }

  // Close modal when clicking outside the video
  const modalEl = document.getElementById("videoModal");
  if (modalEl) {
    modalEl.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (target.id === "videoModal") {
        closeModal();
      }
    });
  }
</script>

---
import Layout from "../layouts/Layout.astro";
const title = "About";

// /bridget-portfolio/assets/wsj-video.png
---

<Layout>
  <h1>About Me</h1>
  <section id="text">
    <div class="images-left">
      <img
        src="/bridget-portfolio/thumb/sbx-hips.jpeg"
        alt="Starbucks"
        class="side-img"
      />
      <img
        src="/bridget-portfolio/thumb/shrek.jpeg"
        alt="Shrek"
        class="side-img"
      />
    </div>
    <div class="text-wrapper">
      <p>
        I'm a Computer Science student specializing in Human–Computer
        Interaction, with a passion for bridging the gap between technology and
        the people who use it. My background spans UX research, digital
        marketing, content strategy, and audience engagement, and I love finding
        where those worlds overlap to tell stories that actually land.
      </p>
      <p>
        Through the Starbucks Green Apron Creator program and building a rapidly
        growing digital media brand from the ground up, I've developed hands-on
        experience in social media strategy, brand partnerships, analytics, and
        content optimization. I'm driven by the belief that the best digital
        experiences aren't just functional; they're meaningful. Helping brands
        connect authentically with their audiences and using data to make those
        connections smarter is work I genuinely care about.
      </p>
      <p>
        When I'm not in research mode or crafting content, you'll find me
        volunteering with the Humane Society of Charlotte, where I work with
        rescue dogs through training programs that help them find their forever
        homes. I'm also a devoted musical theatre fan. From Broadway to local
        productions, there's nothing quite like live performance. And whenever I
        can, I'm traveling, chasing new cultures, perspectives, and the kind of
        experiences that quietly reshape the way you see the world.
      </p>
    </div>
    <div class="images-right">
      <img src="/bridget-portfolio/thumb/tod.jpg" alt="Tod" class="side-img" />
      <img
        src="/bridget-portfolio/thumb/victoria2.jpeg"
        alt="Victoria"
        class="side-img"
      />
    </div>
  </section>
  <div class="spacer"></div>
</Layout>
<style>
  h1 {
    font-family: "Times New Roman", serif;
    font-size: 3rem;
    text-align: center;
    padding-top: 2rem;
    padding-bottom: 1.5rem;
  }

  #text {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    justify-content: center;
    gap: 1.25rem;
    max-width: 1300px;
    margin: 0 auto;
    padding-bottom: 1rem;
  }

  .images-left,
  .images-right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex-shrink: 0;
  }

  .side-img {
    width: 160px;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    outline: 2px solid var(--dark-text);
  }

  .text-wrapper {
    max-width: 800px;
    padding: 1rem 1.5rem;
    outline: 2px solid var(--dark-text);
    background-color: var(--background-color-light);
    flex: 1;
  }

  p {
    margin-top: 1rem;
    font-size: 1.25rem;
    line-height: 1.5rem;
  }

  section {
    min-height: 65vh;
  }

  @media (max-width: 900px) {
    #text {
      flex-direction: column;
      align-items: center;
    }

    .images-left,
    .images-right {
      flex-direction: row;
      justify-content: center;
    }

    .side-img {
      width: 120px;
    }
  }
</style>

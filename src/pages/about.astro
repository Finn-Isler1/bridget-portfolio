---
import Layout from "../layouts/Layout.astro";

const title = "About";
---

<Layout>
  <h1>About Me</h1>
  <section id="text">
    <div class="text-wrapper">
      <p>
        I’m a Computer Science student specializing in Human–Computer Interaction, with experience in digital marketing, content strategy, and audience engagement. My work combines UX research with storytelling to create content and campaigns that resonate with audiences and deliver measurable results.
      </p>
      <p>
        Through the Starbucks Green Apron Creator program and managing a rapidly growing digital media brand, I’ve gained hands-on experience in social media strategy, brand partnerships, analytics, and content optimization.
      </p>
      <p>
        I’m passionate about helping brands connect authentically with audiences and using data-driven insights to improve digital engagement.
      </p>
    </div>
  </section>
  <div class="spacer"></div>
</Layout>
<style>
  h1 {
    font-family: "Times New Roman", serif;
    font-size: 3rem;
    text-align: center;
    padding-top: 2rem;
    padding-bottom: 1.5rem;
  }

  #text {
    max-width: 800px;
    padding-bottom: 1rem;
  }

  p {
    margin-top: 1rem;
    font-size: 1.25rem;
    line-height: 1.5rem;
  }

  section {
    min-height: 65vh;
  }

  .text-wrapper {
    padding: 1rem 1.5rem;
    margin: auto;
    outline: 2px solid var(--dark-text);
    background-color: var(--background-color-light);
  }
</style>

---
import Layout from "../layouts/Layout.astro";

const title = "Home";
---

<Layout>
  <section id="hero">
    <div class="hero--wrapper">
      <div class="hero--text">
        <h1 class="hero--h1">Bridget Baron</h1>
        <h3 class="hero--h3">
          Social Media Strategist | Content Creator | Computer Scientist
        </h3>
        <p>
          I create and manage digital campaigns that connect brands with
          audiences, using content strategy, analytics, and storytelling to
          drive measurable engagement. My work spans social media growth,
          UX-informed content design, and brand collaborations.
        </p>

        <a
          href="/bridget-portfolio/content-creation"
          class="hero--button hero--primary-button">View My Work</a
        >
      </div>
      <div class="picture-wrapper">
        <img
          class="hero--image"
          src="/bridget-portfolio/assets/bridget-pic.jpg"
          alt="Picture of Bridget Baron"
        />

        <div class="hero--button-row">
          <a href="/bridget-portfolio/about" class="hero--button">About</a>
          <a href="/bridget-portfolio/contact" class="hero--button">Contact</a>
        </div>
            <a
             class="hero--wireframe-button-hollow"
              href="/bridget-portfolio/assets/bridget-baron.pdf"
             download="bridget-baron.pdf"
              >
                Download Resume (PDF)
              </a>
      </div>
    </div>
  </section>
  <hr />
  <section id="article">
    <div class="article--wrapper">
      <h1 class="article--h1">Featured Recognition</h1>

      <hr />
      <p class="article--description">
        Recognized by <i>The Wall Street Journal</i> for high-performing digital content,
        featured in coverage mentioned on <i
          >The Tonight Show Starring Jimmy Fallon</i
        >.
      </p>

      <div class="article--link-container">
        <div class="article--item">
          <a
            class="article--link"
            target="_blank"
            href="https://www.wsj.com/lifestyle/workplace/the-new-in-demand-job-skill-being-a-tiktok-influencer-for-your-company-9ca9d232?gaa_at=eafs&gaa_n=AWEtsqevFfYk6nPfLTpv5geYxBbBR8y2gcdNrxL17Ro0G7VIgRJ3FW9o80K9KPlE4dU%3D&gaa_ts=69a4b9c1&gaa_sig=s4lpq9I3Yb1V7yShpMc2iNeD1W1sWPpnZDJN1cruhirwgA2Y9_cZPkaT78STj8NWT_t3_W3m4UDygqaNjKI8gw%3D%3D"
            ><img
              class="article--image"
              src="/bridget-portfolio/thumb/wsj-article.png"
            /></a
          >
          <p class="article--label">WSJ Article</p>
          <a
            class="hero--button"
            target="_blank"
            href="https://www.wsj.com/lifestyle/workplace/the-new-in-demand-job-skill-being-a-tiktok-influencer-for-your-company-9ca9d232?gaa_at=eafs&gaa_n=AWEtsqevFfYk6nPfLTpv5geYxBbBR8y2gcdNrxL17Ro0G7VIgRJ3FW9o80K9KPlE4dU%3D&gaa_ts=69a4b9c1&gaa_sig=s4lpq9I3Yb1V7yShpMc2iNeD1W1sWPpnZDJN1cruhirwgA2Y9_cZPkaT78STj8NWT_t3_W3m4UDygqaNjKI8gw%3D%3D"
            >Read the article</a
          >
        </div>

        <div class="article--item">
          <a
            class="article--link"
            target="_blank"
            href="https://www.wsj.com/video/series/on-the-news/companies-are-creating-their-own-influencer-programs/EFD2A01B-E1C7-45FB-941F-9B0D019E2A97"
            ><img
              class="article--image"
              src="/bridget-portfolio/assets/wsj-video.png"
            /></a
          >
          <p class="article--label">WSJ Video</p>
          <a
            class="hero--button"
            target="_blank"
            href="https://www.wsj.com/video/series/on-the-news/companies-are-creating-their-own-influencer-programs/EFD2A01B-E1C7-45FB-941F-9B0D019E2A97"
            >Watch the video</a
          >
        </div>

        <div class="article--item">
          <a
            class="article--link"
            target="_blank"
            href="https://youtu.be/WV9RuwT7Svg"
            ><img
              class="article--image"
              src="/bridget-portfolio/assets/jimmy-fallon.jpg"
            /></a
          >
          <p class="article--label">Tonight Show Clip</p>
          <a
            class="hero--button"
            target="_blank"
            href="https://youtu.be/WV9RuwT7Svg">View the clip</a
          >
        </div>
      </div>
    </div>
  </section>
  <section id="page-links">
    <div class="page-link-wrapper">
      <a href="/bridget-portfolio/work" class="page-link">
        <img src="/bridget-portfolio/assets/ux-preview.png" alt="Work" />
        <span class="page-link-text">Product Design</span>
      </a>
      <a href="/bridget-portfolio/content-creation" class="page-link">
        <img
          src="/bridget-portfolio/assets/content-creation-preview.png"
          alt="Content Creation"
        />
        <span class="page-link-text">Content Creation</span>
      </a>
      <a href="/bridget-portfolio/content-strategy" class="page-link">
        <img
          src="/bridget-portfolio/thumb/content-strategy-page.png"
          alt="Content Strategy"
        />
        <span class="page-link-text">Content Strategy</span>
      </a>
    </div>
  </section>

  <style>
    section {
      padding: 2rem 0;
    }

    img {
      /* box-shadow: 2px 2px 4px 2px rgb(0 0 0 / 20%); */
    }

    /* HERO SECTION */

    #hero {
    }

    .hero--wrapper {
      display: grid;
      place-items: center;
      max-width: 1000px;
      padding: 0 3rem;
      margin: auto;
      grid-template-columns: 1fr 1fr;
    }

    .hero--text {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      font-size: 1.15rem;
    }

    .hero--button {
      align-self: center;
      width: max-content;
    }

    .hero--wireframe-button-hollow {
  display: block;
  text-align: center;
  margin: auto;
  margin-top: 1rem;
  margin-bottom: 1rem;
  padding: 1rem 1.2rem;
  background-color: var(--background-color-light);
  color: var(--dark-text);
  font-weight: 600;
  font-size: 1.1rem;
  box-shadow: 2px 2px 1px 1px var(--dark-text);
  outline: 1px solid var(--dark-text);
  border-radius: 1rem;
  transition: 0.1s ease;
  width: max-content;
}

.hero--wireframe-button-hollow:hover {
  opacity: 70%;
  cursor: pointer;
}

.hero--wireframe-button-hollow:active {
  transform: translateY(2px) translateX(2px);
  box-shadow: none;
}

    .hero--h1 {
      font-size: 4rem;
      font-family: var(--serif);
      font-weight: 500;
      margin-bottom: 1rem;
    }

    .hero--h2 {
      font-size: 2rem;
      margin-bottom: 2rem;
      font-weight: 200;
    }

    .hero--h3 {
      font-size: 1rem;
      text-align: left;
      width: 100%;
      font-weight: 600;
      margin-bottom: 2rem;
    }

    .hero--image {
      width: 16rem;
      /* border-radius: 1rem; */
      height: auto;
    }

    .picture-wrapper {
      background-color: var(--background-color-light);
      padding: 1.5rem;
      outline: 2px solid var(--dark-text);
    }

    .hero--button-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: center;
      margin-top: 1rem;
    }

    .hero--button {
      padding: 1rem 2rem;
      background-color: var(--primary-color);
      color: var(--light-text);
      font-weight: 600;
      font-size: 1rem;
      box-shadow: 2px 2px 1px 1px var(--dark-text);
      text-align: center;
      border-radius: 1rem;
      transition: 0.1s ease;
    }

    .hero--primary-button {
      margin-top: 2rem;
    }

    .hero--button:hover {
      opacity: 70%;
      cursor: pointer;
    }

    .hero--button:active {
      transform: translateY(2px) translateX(2px);
      box-shadow: none;
    }

    /* ARTICLE SECTION */

    .article--wrapper {
      max-width: 1000px;
      margin: auto;
      padding: 1rem 1.5rem;
      outline: 2px solid var(--dark-text);
      background-color: var(--background-color-light);
    }

    .article--h1 {
      font-family: var(--serif);
      font-size: 3rem;
    }

    .article--description {
      font-size: 1.25rem;
    }

    .article--link-container {
      margin-top: 2rem;
      margin-bottom: 2rem;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .article--link {
      display: flex;
      width: 90%;
      margin: auto;
      align-items: center;
      justify-content: center;
      border-radius: 70px;
      transition: 0.1s ease;
    }

    .article--link:hover {
      opacity: 0.7;
    }

    .article--image {
      width: 100%;
      height: 200px;
      object-fit: cover;
      border-radius: 1.5rem;
      /* box-shadow: 2px 2px 4px 1px var(--dark-text); */
    }

    .article--item {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .article--button {
      margin-top: 1rem;
      padding: 0.75rem 1.5rem;
      background-color: var(--primary-color);
      color: var(--light-text);
      font-weight: 600;
      font-size: 1rem;
      text-align: center;
      border-radius: 1rem;
      text-decoration: none;
      transition: 0.1s ease;
    }

    .article--button:hover {
      opacity: 0.7;
    }

    .article--button:active {
      transform: translateY(2px) translateX(2px);
      box-shadow: none;
    }

    .article--label {
      margin: 0.5rem 0;
      font-size: 1rem;
      font-weight: 600;
      text-align: center;
    }
    /* PROJETS */

    /* CONTACT */
    .contact--button {
      padding: 1rem 2rem;
      background-color: var(--primary-color);
      color: var(--light-text);
      font-weight: 600;
      font-size: 1rem;
      box-shadow: 2px 2px 1px 1px var(--dark-text);

      border-radius: 1rem;
      margin: auto;
      margin-top: 2rem;
      transition: 0.1s ease;
    }

    .contact--button:hover {
      opacity: 70%;
      cursor: pointer;
    }

    .contact--button:active {
      transform: translateY(2px) translateX(2px);
      box-shadow: none;
    }

    i {
      font-style: italic;
    }

    /* PAGE LINKS */
    #page-links {
      padding: 2rem 0;
    }

    .page-link-wrapper {
      display: flex;
      flex-direction: row-reverse;
      gap: 2rem;
      justify-content: center;
      max-width: 1200px;
      margin: auto;
      padding: 0 2rem;
    }

    .page-link {
      position: relative;
      display: block;
      width: 300px;
      height: 200px;
      overflow: hidden;
      border-radius: 1rem;
      outline: 2px solid var(--dark-text);
      transition: 0.2s ease;
    }

    .page-link:hover {
      transform: scale(1.05);
      opacity: 80%;
    }

    .page-link img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      outline: 2px solid var(--dark-text);
    }

    .page-link-text {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: var(--light-text);
      font-size: 1.25rem;

      font-weight: 600;
      text-align: center;
      background-color: var(--primary-color);
      border-radius: 1rem;
      padding: 0.25rem 0.75rem;
      /* outline: 2px solid var(--dark-text); */
      box-shadow: 2px 2px 4px 1px var(--dark-text);
      opacity: 98%;
    }

    @media (max-width: 768px) {
      .hero--wrapper {
        grid-template-columns: 1fr;
        padding: 0 1rem;
      }

      .hero--h1 {
        font-size: 2.5rem;
      }

      .hero--h2 {
        font-size: 1.5rem;
      }

      .hero--image {
        width: 12rem;
        margin: 0.5rem;
      }

      .picture-wrapper {
        padding: 1.5rem;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .hero--primary-button {
        margin-bottom: 1.5rem;
      }

      .article--link-container {
        grid-template-columns: 1fr;
      }

      .page-link-wrapper {
        flex-direction: column;
        gap: 1rem;
      }

      .page-link {
        width: 100%;
        max-width: 300px;
      }
    }
  </style>


</Layout>
